{
    "name": "memeseek",
    "private": true,
    "packageManager": "pnpm@9.11.0",
    "scripts": {
        "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
        "dev:client": "pnpm --filter client dev",
        "dev:server": "pnpm --filter server start:dev"
